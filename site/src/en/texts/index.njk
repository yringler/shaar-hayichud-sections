---
title: Texts
layout: layouts/base.njk
eleventyExcludeFromCollections: true
permalink: /texts/
---
<h1>{{ i18n[lang].nav.texts }}</h1>

<ul class="index-list">
  {% for text in collections.texts %}
    {% if text.data.lang == lang %}
    <li><a href="{{ text.url }}">{{ text.data.title }}</a></li>
    {% endif %}
  {% endfor %}
</ul>
