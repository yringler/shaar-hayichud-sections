---
layout: layouts/base.njk
title: Home
eleventyExcludeFromCollections: true
---
<h1>{{ site.title }}</h1>
<p>{{ site.description }}</p>

<section>
  <h2>{{ i18n[lang].nav.texts }}</h2>
  <ul class="index-list">
    {% for file in xmlFiles %}
      {% set n = file | replace("chapter_", "") | replace(".xml", "") | int %}
      <li><a href="/he/texts/chapter-{{ n }}/">Chapter {{ n }}</a></li>
    {% else %}
    <li>No texts yet.</li>
    {% endfor %}
  </ul>
</section>

<section>
  <h2>{{ i18n[lang].nav.classes }}</h2>
  <ul class="index-list">
    {% for series in classes %}
    <li><a href="/classes/{{ series.title | slugify }}/">{{ series.title }}</a></li>
    {% else %}
    <li>No classes yet.</li>
    {% endfor %}
  </ul>
</section>
