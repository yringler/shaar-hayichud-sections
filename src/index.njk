---
layout: layouts/base.njk
title: Home
---
<h1>{{ site.title }}</h1>
<p>{{ site.description }}</p>

<section>
  <h2>Texts</h2>
  <ul class="index-list">
    {% for item in collections.texts %}
    <li><a href="{{ item.url }}">{{ item.data.title }}</a></li>
    {% else %}
    <li>No texts yet.</li>
    {% endfor %}
  </ul>
</section>

<section>
  <h2>Classes</h2>
  <ul class="index-list">
    {% for item in collections.classes %}
    <li><a href="{{ item.url }}">{{ item.data.title }}</a></li>
    {% else %}
    <li>No classes yet.</li>
    {% endfor %}
  </ul>
</section>
