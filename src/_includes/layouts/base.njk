<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    body {
      max-width: 70ch;
      margin: 2em auto;
      padding: 0 1em;
      font-family: serif;
      line-height: 1.7;
      direction: rtl;
      color: #111;
    }

    /* ── Nav ── */
    nav {
      display: flex;
      gap: 1.5em;
      padding-block-end: 0.75em;
      margin-block-end: 1.5em;
      border-block-end: 1px solid #ddd;
      font-family: sans-serif;
      font-size: 0.9em;
    }

    nav a {
      color: inherit;
      text-decoration: none;
    }

    nav a:hover {
      text-decoration: underline;
    }

    /* ── Main content ── */
    main a {
      color: inherit;
    }

    /* ── XSL-generated section structure ── */
    div[class^="depth-"] {
      display: flex;
      gap: 0.75em;
      margin-block: 0.75em;
    }

    .depth-1 { padding-inline-start: 1em; }
    .depth-2 { padding-inline-start: 2em; }
    .depth-3 { padding-inline-start: 3em; }
    .depth-4 { padding-inline-start: 4em; }
    .depth-5 { padding-inline-start: 5em; }

    .label {
      font-weight: bold;
      flex-shrink: 0;
    }

    .number {
      color: #888;
      font-size: 0.85em;
      margin-inline-end: 0.3em;
    }

    .content {
      color: #222;
    }

    /* ── Index lists ── */
    ul.index-list {
      list-style: none;
      padding: 0;
    }

    ul.index-list li {
      margin-block: 0.5em;
    }

    ul.index-list a {
      color: inherit;
    }

    /* ── Lesson audio ── */
    .back-link {
      font-family: sans-serif;
      font-size: 0.9em;
      margin-block-end: 1.5em;
    }

    .lesson-audio {
      margin-block: 1em;
    }

    .audio-title {
      margin-block-end: 0.3em;
      font-weight: bold;
    }

    audio {
      width: 100%;
      display: block;
    }

    @media (max-width: 600px) {
      .label {
        max-width: 10ch;
        overflow-wrap: break-word;
        hyphens: auto;
      }
    }
  </style>
</head>
<body>
  <nav>
    <a href="/">{{ site.title }}</a>
    <a href="/texts/">Texts</a>
    <a href="/classes/">Classes</a>
  </nav>
  <main>
    {{ content | safe }}
  </main>
</body>
</html>
