<!DOCTYPE html>
<html lang="{{ lang }}" dir="{{ dir }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  {% for link in page.url | locale_links %}
  <link rel="alternate" hreflang="{{ link.lang }}" href="{{ site.url }}{{ link.url }}">
  {% endfor %}
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    body {
      max-width: 70ch;
      margin: 2em auto;
      padding: 0 1em;
      font-family: serif;
      line-height: 1.7;
      color: #111;
    }

    /* ── Nav ── */
    nav {
      display: flex;
      gap: 1.5em;
      padding-block-end: 0.75em;
      margin-block-end: 1.5em;
      border-block-end: 1px solid #ddd;
      font-family: sans-serif;
      font-size: 0.9em;
    }

    nav a {
      color: inherit;
      text-decoration: none;
    }

    nav a:hover {
      text-decoration: underline;
    }

    .lang-switch {
      margin-inline-start: auto;
      color: #666;
    }

    /* ── Main content ── */
    main a {
      color: inherit;
    }

    /* ── XSL-generated section structure ── */
    div[class^="depth-"] {
      display: flex;
      gap: 0.75em;
      margin-block: 0.75em;
    }

    .depth-1 { padding-inline-start: 1em; }
    .depth-2 { padding-inline-start: 2em; }
    .depth-3 { padding-inline-start: 3em; }
    .depth-4 { padding-inline-start: 4em; }
    .depth-5 { padding-inline-start: 5em; }

    .label {
      font-weight: bold;
      flex-shrink: 0;
    }

    .number {
      color: #888;
      font-size: 0.85em;
      margin-inline-end: 0.3em;
    }

    .content {
      color: #222;
    }

    /* ── Index lists ── */
    ul.index-list {
      list-style: none;
      padding: 0;
    }

    ul.index-list li {
      margin-block: 0.5em;
    }

    ul.index-list a {
      color: inherit;
    }

    @media (max-width: 600px) {
      .label {
        max-width: 10ch;
        overflow-wrap: break-word;
        hyphens: auto;
      }
    }

    /* ── Audio class pages (LTR English content) ── */
    .ltr-content {
      direction: ltr;
      text-align: start;
    }

    .ltr-content .breadcrumb {
      font-family: sans-serif;
      font-size: 0.85em;
      color: #666;
      margin-block-end: 1.5em;
    }

    .ltr-content .breadcrumb a { color: #666; }

    .ltr-content .part-list {
      list-style: none;
      padding: 0;
    }

    .ltr-content .part-list li {
      margin-block: 0.6em;
      display: flex;
      align-items: baseline;
      gap: 0.75em;
    }

    .ltr-content .part-list .track-count {
      font-size: 0.8em;
      color: #888;
      white-space: nowrap;
    }

    .ltr-content .chapter-section {
      margin-block: 1.5em;
    }

    .ltr-content .chapter-section h2 {
      font-size: 1.05em;
      font-family: sans-serif;
      padding-block-end: 0.3em;
      border-block-end: 1px solid #ddd;
      margin-block-end: 0.75em;
    }

    .ltr-content .track {
      margin-block: 0.75em;
    }

    .ltr-content .track audio {
      display: block;
      width: 100%;
      margin-block-end: 0.2em;
    }

    .ltr-content .track-title {
      font-size: 0.85em;
      color: #555;
    }
  </style>
</head>
<body>
  <nav>
    <a href="/{{ lang }}/">{{ i18n[lang].nav.home }}</a>
    <a href="/{{ lang }}/texts/">{{ i18n[lang].nav.texts }}</a>
    {% if lang == "en" %}<a href="/en/translation/">Translation</a>{% endif %}
    <a href="/en/classes/">{{ i18n[lang].nav.classes }}</a>
    <a href="/en/about/">{{ i18n[lang].nav.about }}</a>
    {% for link in page.url | locale_links %}
      {% if link.lang != lang %}
    <a class="lang-switch" href="{{ link.url }}" hreflang="{{ link.lang }}">{{ i18n[link.lang].langName }}</a>
      {% endif %}
    {% endfor %}
  </nav>
  <main>
    {{ content | safe }}
  </main>
</body>
</html>
